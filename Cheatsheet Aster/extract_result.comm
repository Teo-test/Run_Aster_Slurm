# ==============================================================================
# 7. MÉTRIQUES D'ERREUR
#    a = champ approché (modifié), r = champ de référence
# ==============================================================================

def erreur_L1(a, r):
    """Erreur L1 relative [%] : Σ|a−r| / Σ|r|"""
    return 100. * np.sum(np.abs(a - r)) / np.sum(np.abs(r))

def erreur_L2(a, r):
    """Erreur L2 relative [%] : ‖a−r‖ / ‖r‖"""
    return 100. * np.linalg.norm(a - r) / np.linalg.norm(r)

def erreur_Linf(a, r):
    """Erreur L∞ relative [%] : max|a−r| / max|r|"""
    return 100. * np.max(np.abs(a - r)) / np.max(np.abs(r))

def rmse(a, r):
    """Root Mean Square Error (unités du champ)"""
    return float(np.sqrt(np.mean((a - r)**2)))

def biais(a, r):
    """Biais = décalage systématique moyen = mean(a − r)"""
    return float(np.mean(a - r))

def rapport_erreur(label, a, r):
    """Affiche toutes les métriques pour un champ (+ print console)."""
    ligne = (f"{label:<22s} | "
             f"L2={erreur_L2(a,r):5.2f}% | "
             f"Linf={erreur_Linf(a,r):5.2f}% | "
             f"L1={erreur_L1(a,r):5.2f}% | "
             f"RMSE={rmse(a,r):.3e} | "
             f"Biais={biais(a,r):+.3e}")
    print(ligne)
    return ligne

# ==============================================================================
# 8. EXPORT CSV / TXT
# ==============================================================================

SCRATCH  = os.environ.get('SCRATCH', '/tmp')
JOB_ID   = os.environ.get('SLURM_JOB_ID', 'local')
OUT_DIR  = os.path.join(SCRATCH, f'resultats_{JOB_ID}')
os.makedirs(OUT_DIR, exist_ok=True)

TXT_PATH = os.path.join(OUT_DIR, 'resume_erreurs.txt')
CSV_PATH = os.path.join(OUT_DIR, 'resume_erreurs.csv')

# En-tête CSV (première exécution seulement)
if not os.path.exists(CSV_PATH):
    with open(CSV_PATH, 'w', newline='') as f:
        csv.writer(f).writerow(['PARAM', 'LABEL', 'L2%', 'Linf%', 'L1%', 'RMSE', 'Biais'])

# Dictionnaire des grandeurs à comparer : label → (modifié, référence)
grandeurs = {
    'Sxx [MPa]'       : (sig_md[:, 0], sig_ref[:, 0]),
    'Syy [MPa]'       : (sig_md[:, 1], sig_ref  [:, 1]),
    'Szz [MPa]'       : (sig_md[:, 2], sig_ref  [:, 2]),
    'Sxy [MPa]'       : (sig_md[:, 3], sig_ref  [:, 3]),
    'Sxz [MPa]'       : (sig_md[:, 4], sig_ref  [:, 4]),
    'Syz [MPa]'       : (sig_md[:, 5], sig_ref  [:, 5]),
    'Von Mises [MPa]' : (vm_md,        vm_ref),
    'DX [mm]'         : (dep_md[:, 0], dep_ref[:, 0]),
    'DY [mm]'         : (dep_md[:, 1], dep_ref[:, 1]),
    'DZ [mm]'         : (dep_md[:, 2], dep_ref[:, 2]),
    'U [mm]'          : (U_md,         U_ref),
}

# Export TXT (rapport lisible, mode append)
with open(TXT_PATH, 'a') as f:
    f.write(f"Parametre : {valeur_param}\n")
    f.write("-" * 80 + "\n")
    for label, (a, r) in grandeurs.items():
        ligne = rapport_erreur(label, a, r)
        f.write(ligne + "\n")
    f.write("\n")

# Export CSV (mode append, exploitable par comparecsv_v3.py ou pandas)
with open(CSV_PATH, 'a', newline='') as f:
    writer = csv.writer(f)
    for label, (a, r) in grandeurs.items():
        writer.writerow([
            valeur_param, label,
            f"{erreur_L2(a,r):.4f}",
            f"{erreur_Linf(a,r):.4f}",
            f"{erreur_L1(a,r):.4f}",
            f"{rmse(a,r):.6e}",
            f"{biais(a,r):+.6e}",
        ])
