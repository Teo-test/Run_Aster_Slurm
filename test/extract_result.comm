import numpy as np
import os
import csv

# ============================================================
# 1. RECUPERATION DES VALEURS
# ============================================================

params_ref = resu_ref.getAccessParameters()
params_md  = resu_md.getAccessParameters()

num_ref = int(params_ref['NUME_ORDRE'][-1])
num_md  = int(params_md['NUME_ORDRE'][-1])

sig_ref = np.array(resu_ref.getField('SIGM_NOEU', num_ref).getValues()).reshape(-1, 6)
sig_md  = np.array(resu_md.getField('SIGM_NOEU',  num_md).getValues()).reshape(-1, 6)
dep_ref = np.array(resu_ref.getField('DEPL',       num_ref).getValues()).reshape(-1, 3)
dep_md  = np.array(resu_md.getField('DEPL',        num_md).getValues()).reshape(-1, 3)

# ============================================================
# 2. VON MISES
# ============================================================

def von_mises(sig):
    sxx, syy, szz = sig[:,0], sig[:,1], sig[:,2]
    sxy, sxz, syz = sig[:,3], sig[:,4], sig[:,5]
    return np.sqrt(0.5 * (
        (sxx-syy)**2 + (syy-szz)**2 + (szz-sxx)**2
        + 6*(sxy**2 + sxz**2 + syz**2)
    ))

vm_ref = von_mises(sig_ref)
vm_md  = von_mises(sig_md)

# ============================================================
# 3. FONCTIONS D'ERREUR
# ============================================================

def erreur_L1(a, r):
    return 100. * np.sum(np.abs(a - r)) / np.sum(np.abs(r))

def erreur_L2(a, r):
    return 100. * np.linalg.norm(a - r) / np.linalg.norm(r)

def erreur_Linf(a, r):
    return 100. * np.max(np.abs(a - r)) / np.max(np.abs(r))

def rmse(a, r):
    return float(np.sqrt(np.mean((a - r)**2)))

def biais(a, r):
    return float(np.mean(a - r))

# ============================================================
# 4. EXPORT
# ============================================================

SCRATCH  = os.environ.get('SCRATCH', '/tmp')
JOB_ID   = os.environ.get('SLURM_JOB_ID', 'local')
OUT_DIR  = os.path.join(SCRATCH, f'resultats_{JOB_ID}')
os.makedirs(OUT_DIR, exist_ok=True)

TXT_PATH = os.path.join(OUT_DIR, 'resume_erreurs.txt')
CSV_PATH = os.path.join(OUT_DIR, 'resume_erreurs.csv')

grandeurs = {
    'Von Mises [MPa]' : (vm_md,       vm_ref),
    'DX [mm]'         : (dep_md[:,0], dep_ref[:,0]),
    'DY [mm]'         : (dep_md[:,1], dep_ref[:,1]),
    'DZ [mm]'         : (dep_md[:,2], dep_ref[:,2]),
}

with open(TXT_PATH, 'a') as f:
    f.write(f"Parametre : {valeur_param}\n")
    f.write("-" * 80 + "\n")
    for label, (a, r) in grandeurs.items():
        ligne = (f"{label:<20s} | "
                 f"L2={erreur_L2(a,r):5.2f}% | "
                 f"Linf={erreur_Linf(a,r):5.2f}% | "
                 f"L1={erreur_L1(a,r):5.2f}% | "
                 f"RMSE={rmse(a,r):.3e} | "
                 f"Biais={biais(a,r):+.3e}\n")
        f.write(ligne)
        print(ligne, end='')
    f.write("\n")

with open(CSV_PATH, 'a', newline='') as f:
    writer = csv.writer(f)
    for label, (a, r) in grandeurs.items():
        writer.writerow([
            valeur_param, label,
            f"{erreur_L2(a,r):.4f}",
            f"{erreur_Linf(a,r):.4f}",
            f"{erreur_L1(a,r):.4f}",
            f"{rmse(a,r):.6e}",
            f"{biais(a,r):+.6e}",
        ])